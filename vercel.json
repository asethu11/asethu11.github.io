    {
      "source": "/script.js",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "destination": "/script.js"
    },
    {
      "source": "/shared.js",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "destination": "/shared.js"
