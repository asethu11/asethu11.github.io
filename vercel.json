{
  "version": 2,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "destination": "/blogs/$1"
    },
    {
      "source": "/improvingAdoption",
      "destination": "/improvingAdoption/"
    },
    {
      "source": "/nextgen",
      "destination": "/nextgen/"
    },
    {
      "source": "/ytm",
      "destination": "/ytm/"
    },
    {
      "source": "/LSR",
      "destination": "/LSR/"
    },
    {
      "source": "/SODA",
      "destination": "/SODA/"
    },
    {
      "source": "/cabKb",
      "destination": "/cabKb/"
    },
    {
      "source": "/COMUT",
      "destination": "/COMUT/"
    }
  ],
  "redirects": [
    {
      "source": "/my-works/improving-adoption/improvingAdoption.html",
      "destination": "https://abseth.com/improvingAdoption",
      "permanent": true
    },
    {
      "source": "/my-works/nextgen/nextgen.html",
      "destination": "https://abseth.com/nextgen",
      "permanent": true
    },
    {
      "source": "/my-works/ytm/ytm.html",
      "destination": "https://abseth.com/ytm",
      "permanent": true
    },
    {
      "source": "/my-works/LSR/LSR.html",
      "destination": "https://abseth.com/LSR",
      "permanent": true
    },
    {
      "source": "/my-works/hackathonSODA/SODA.html",
      "destination": "https://abseth.com/SODA",
      "permanent": true
    },
    {
      "source": "/my-works/KB-ET/cabKb.html",
      "destination": "https://abseth.com/cabKb",
      "permanent": true
    },
    {
      "source": "/my-works/usertesting-mesa/COMUT.html",
      "destination": "https://abseth.com/COMUT",
      "permanent": true
    },
    {
      "source": "/blogs/:path*",
      "destination": "https://blogs.abseth.com/:path*",
      "permanent": true
    },
    {
      "source": "/blogs/:slug/:slug.html",
      "destination": "https://blogs.abseth.com/:slug",
      "permanent": true
    },
    {
      "source": "/blogs/:slug/index.html",
      "destination": "https://blogs.abseth.com/:slug",
      "permanent": true
    },
    {
      "source": "/:slug.html",
      "destination": "https://abseth.com/:slug",
      "permanent": true
    },
    {
      "source": "/:any/index.html",
      "destination": "https://abseth.com/:any",
      "permanent": true
    },
  ]
}
