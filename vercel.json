      "destination": "https://blogs.abseth.com/Conversational-UX/",
      "permanent": true
    },
    {
      "source": "/your-chatbot-sucks-lets-fix-that/:path*",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "destination": "https://blogs.abseth.com/Conversational-UX/",
      "permanent": true
    },
    {
      "source": "/Conversational-UX",
      "has": [{ "type": "host", "value": "abseth.com" }],
      "destination": "https://blogs.abseth.com/Conversational-UX/",
