{
  "routes": [
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "about.abseth.com" }],
      "dest": "/about.html"
    },
    {
      "src": "^/$",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "dest": "/blogs.html"
    },
    {
      "src": "^/([^/]+)/?$",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "dest": "/blogs/$1/index.html"
    },
    {
      "src": "^/improvingAdoption/?$",
      "dest": "/my-works/improving-adoption/improvingAdoption.html"
    },
    {
      "src": "^/nextgen/?$",
      "dest": "/my-works/nextgen/nextgen.html"
    },
    {
      "src": "^/ytm/?$",
      "dest": "/my-works/ytm/ytm.html"
    },
    {
      "src": "^/LSR/?$",
      "dest": "/my-works/LSR/LSR.html"
    },
    {
      "src": "^/SODA/?$",
      "dest": "/my-works/hackathonSODA/SODA.html"
    },
    {
      "src": "^/cabKb/?$",
      "dest": "/my-works/KB-ET/cabKb.html"
    },
    {
      "src": "^/COMUT/?$",
      "dest": "/my-works/usertesting-mesa/COMUT.html"
    }
  ]
}
