    {
      "source": "/Conversational-UX/:path*",
      "has": [{ "type": "host", "value": "abseth.com" }],
      "destination": "https://blogs.abseth.com/Conversational-UX/",
      "permanent": true
    },
    {
      "source": "/:slug/:file.html",
      "has": [{ "type": "host", "value": "blogs.abseth.com" }],
      "destination": "https://blogs.abseth.com/:slug",
      "permanent": true
    },
    {
      "source": "/blogs/:path*",
      "destination": "https://blogs.abseth.com/:path*",
      "permanent": true
    },
    {
      "source": "/:slug.html",
      "destination": "/:slug",
      "permanent": true
    },
    {
      "source": "/:path+/index.html",
      "destination": "/:path*",
      "permanent": true
    }
  ]
